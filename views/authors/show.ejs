<div class="author-details-container">
    <div class="author-details-header">
        <h2 class="page-header"><i class="fas fa-user-edit"></i> <%= author.name %></h2>
        <div class="btn-row">
            <% if (!author.isProtected) { %>
                <a class="btn btn-primary" href="/authors/<%= author.id %>/edit">Edit</a>
                <%- include('../partials/deleteForm',
                            { url: `/authors/${author.id}` }) %>
            <% } %>
        </div>
    </div>
</div>

<% if (booksByAuthor.length > 0) { %>
    <div class="author-books-section">
        <h2 class="page-header section-divider">Books By <%= author.name %></h2>
        <%- include('../partials/bookGrid', { books: booksByAuthor }) %>
    </div>
<% } %>